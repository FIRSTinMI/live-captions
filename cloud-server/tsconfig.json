{
    "compilerOptions": {
        "target": "ES2020",
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "./build",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "composite": true,
        "declaration": true,
        "declarationMap": true
    },
    "include": ["src"],
    "exclude": ["src/admin", "node_modules"]
}
