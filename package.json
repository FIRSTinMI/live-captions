{
    "name": "live-captions",
    "version": "1.9.2",
    "main": "./build/index.js",
    "bin": "./build/index.js",
    "scripts": {
        "start": "bun run ./src/index.ts --skip-update-check",
        "start-gibberish": "tsc && node ./build/index.js --gibberish",
        "build:frontend": "vite build",
        "dev:frontend": "vite",
        "dist": "npm run build:frontend && tsc && npx @yao-pkg/pkg .",
        "test": "bun test"
    },
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@google-cloud/speech": "^6.7.1",
        "@materializecss/materialize": "^2.2.2",
        "@trpc/server": "^11.14.1",
        "audify": "^1.10.1",
        "bad-words": "^3.0.4",
        "body-parser": "^1.20.3",
        "colorts": "^0.1.63",
        "express": "^4.21.2",
        "express-ws": "^5.0.2",
        "pumpify": "^2.0.1",
        "ws": "^8.18.3",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@tanstack/react-query": "^5.94.5",
        "@trpc/client": "^11.14.1",
        "@trpc/react-query": "^11.14.1",
        "@types/bad-words": "^3.0.3",
        "@types/cli-progress": "^3.11.6",
        "@types/express": "^4.17.25",
        "@types/express-ws": "^3.0.6",
        "@types/node": "^20.19.25",
        "@types/pumpify": "^1.4.5",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "@yao-pkg/pkg": "^6.14.1",
        "bun-types": "latest",
        "lorem-ipsum": "^2.0.8",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "typescript": "^5.9.3",
        "vite": "^8.0.1"
    },
    "pkg": {
        "targets": [
            "node22-windows-x64"
        ],
        "assets": [
            "./build/public/**/*",
            "./node_modules/audify/**/*",
            "./dist/april-asr/april-asr.exe"
        ],
        "outputPath": "dist",
        "entry": "./build/index.js"
    }
}
