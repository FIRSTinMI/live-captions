{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "allowImportingTsExtensions": true,
        "noEmit": true,
        "paths": {
            "../../trpc/router": ["./src/trpc/router.ts"]
        }
    },
    "include": ["src/frontend", "src/trpc", "src/util/eventBus.ts", "src/types", "vite.config.ts"],
    "exclude": ["node_modules"]
}
